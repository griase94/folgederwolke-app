# =============================================================================
# .env.test — committed test defaults targeting docker-compose Postgres.
# Loaded by tests/playwright-global-setup.ts and tests/vitest-global-setup.ts.
# Override via .env.test.local (gitignored) for local-only tweaks.
# =============================================================================

# --- Database (test DB on same docker compose Postgres, port 15432) ----------
DATABASE_URL=postgres://app_runtime:app_runtime@localhost:15432/folgederwolke_test
DIRECT_DATABASE_URL=postgres://postgres:postgres@localhost:15432/folgederwolke_test

# --- Auth --------------------------------------------------------------------
SESSION_SECRET=test-only-not-secret-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- File storage (local-fs impl writes to ./.dev-data/drive-test/) ----------
STORAGE_BACKEND=local-fs
FILE_STORAGE_ROOT=./.dev-data/drive-test

# --- Mail (no-op — writes sent_mails row, no I/O, deterministic) -------------
MAIL_PROVIDER=no-op
MAIL_FROM=test@folgederwolke.local

# --- Admin (test fixtures expect admin@example.com on the allowlist) ---------
ADMIN_EMAILS=admin@example.com

# --- Feature flags -----------------------------------------------------------
PUBLIC_FORM_ENABLED=true

# --- Org constants (quoted because parens trip bash's source) ----------------
VEREIN_NAME="Folge der Wolke e.V. (TEST)"
VEREIN_STEUERNUMMER=143/215/10028
VEREIN_VR="VR 211227"
VEREIN_ADRESSE="Westermühlstraße 6, 80469 München"
# Verein bank data — placeholder Deutsche Skatbank pair (BLZ 83065408 ↔
# GENODEF1XXX). The IBAN check-digits are deliberately invalid (00) so
# anyone reading this knows it's not a real account; real production
# values live ONLY in Vercel env. The BLZ + BIC prefix still match so
# the startup consistency check passes (cycle-2 review F2).
VEREIN_IBAN=DE00830654089999999999
VEREIN_BIC=GENODEF1XXX
VEREIN_BANK="Deutsche Skatbank (placeholder — set real value in Vercel env)"
