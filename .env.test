# =============================================================================
# .env.test — committed test defaults targeting docker-compose Postgres.
# Loaded by tests/playwright-global-setup.ts and tests/vitest-global-setup.ts.
# Override via .env.test.local (gitignored) for local-only tweaks.
# =============================================================================

# --- Database (test DB on same docker compose Postgres, port 15432) ----------
DATABASE_URL=postgres://app_runtime:app_runtime@localhost:15432/folgederwolke_test
DIRECT_DATABASE_URL=postgres://postgres:postgres@localhost:15432/folgederwolke_test

# --- Auth --------------------------------------------------------------------
SESSION_SECRET=test-only-not-secret-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- File storage (local-fs impl writes to ./.dev-data/files-test/) ----------
# Phase 9: tests never hit Vercel Blob; BLOB_READ_WRITE_TOKEN is left blank.
STORAGE_BACKEND=local-fs
FILE_STORAGE_ROOT=./.dev-data/files-test
BLOB_READ_WRITE_TOKEN=

# --- Google service account (Phase 9): unset in tests — tests that need ------
# Sheets stub env.googleServiceAccount or mock the Sheets client directly.
GOOGLE_SERVICE_ACCOUNT_KEY_JSON=
FINANCE_SHEET_ID=

# --- Mail (no-op — writes sent_mails row, no I/O, deterministic) -------------
MAIL_PROVIDER=no-op
MAIL_FROM=test@folgederwolke.local

# --- Admin (test fixtures expect admin@example.com on the allowlist) ---------
ADMIN_EMAILS=admin@example.com

# --- Feature flags -----------------------------------------------------------
PUBLIC_FORM_ENABLED=true

# Public-form consent contact email (build-time PUBLIC_ var, read via
# $env/static/public in $lib/domain/datenschutz.ts — client-importable, so it
# can NOT use the server env.ts). Neutral TEST value; real value lives in Vercel.
PUBLIC_VEREIN_KONTAKT_EMAIL=info@test-verein.de

# --- Org constants (quoted because parens trip bash's source) ----------------
VEREIN_NAME="Folge der Wolke e.V. (TEST)"
VEREIN_STEUERNUMMER=143/215/10028
VEREIN_VR="VR 211227"
VEREIN_ADRESSE="Westermühlstraße 6, 80469 München"
# Verein bank data — placeholder Deutsche Skatbank pair (BLZ 83065408 ↔
# GENODEF1XXX). The IBAN check-digits are deliberately invalid (00) so
# anyone reading this knows it's not a real account; real production
# values live ONLY in Vercel env. The BLZ + BIC prefix still match so
# the startup consistency check passes (cycle-2 review F2).
VEREIN_IBAN=DE43830654089999999999
VEREIN_BIC=GENODEF1XXX
VEREIN_BANK="Deutsche Skatbank (placeholder — set real value in Vercel env)"

# Phase 10 — Rechnung v2 footer fields.
VEREIN_KONTAKT_PERSON="Jonas Hackenberg"
VEREIN_CONTACT_PHONE="+49 176 / 81566960"

# White-label Phase 1 — legal/tax identity vars (neutral TEST values; the real
# "Folge der Wolke" data lives ONLY in Vercel prod env, never committed here).
VEREIN_FINANZAMT="Finanzamt Teststadt"
VEREIN_VORSTAND="Test Vorstand"
VEREIN_KONTAKT_EMAIL="kontakt@example.test"
VEREIN_AUFSICHTSBEHOERDE="Test-Aufsichtsbehörde, Teststadt"
VEREIN_REGISTERGERICHT="Amtsgericht Teststadt"
# Steuerbegünstigte Zwecke — must be non-empty so cert-issuing test paths render
# (the FdW-specific schema default was removed in white-label Phase 1).
VEREIN_STEUERBEGUENSTIGTE_ZWECKE="der Förderung des Tests"
# Default Mitgliedsbeitrag (integer cents).
VEREIN_BEITRAG_DEFAULT_CENTS=6969
