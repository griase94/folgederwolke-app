# nosemgrep: package_managers.npm.npm-missing-minimum-release-age.npm-missing-minimum-release-age
# This project runs pnpm exclusively (packageManager: pnpm@10.11.1 in package.json,
# no bare `npm` invocations anywhere in CI). npm's `min-release-age` key (npm >=11.10)
# has no effect under pnpm. pnpm's equivalent, `minimumReleaseAge` (key `minimum-release-age`
# here, value in MINUTES not days), was only introduced in pnpm 10.16 -- newer than the
# version this repo pins. Adding either key today would be a silent no-op, not real
# protection. Follow-up: bump the pinned pnpm version to >=10.16 and set
# `minimum-release-age=10080` (7 days) once that bump has been tested independently.
engine-strict=true
onlyBuiltDependencies:
  - sharp
  - esbuild
