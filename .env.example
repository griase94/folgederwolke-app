# =============================================================================
# folgederwolke-app — environment variable template
# Copy to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# --- Neon Postgres -----------------------------------------------------------
DATABASE_URL=                        # Pooled URL (port 5432, ?sslmode=require)
DIRECT_DATABASE_URL=                 # Direct URL for drizzle-kit migrations

# --- Auth --------------------------------------------------------------------
SESSION_SECRET=                      # openssl rand -base64 64

# --- File storage (Phase 9) --------------------------------------------------
STORAGE_BACKEND=blob                 # blob (prod) | local-fs (dev/test only)
BLOB_READ_WRITE_TOKEN=               # Vercel Blob store token (Vercel auto-provisions)
FILE_STORAGE_ROOT=                   # only used when STORAGE_BACKEND=local-fs

# --- Google service account (Phase 9) ----------------------------------------
# Full JSON contents of the SA key, on a single line (escaped quotes).
# Used by sheet-reader.ts (legacy importer) and finance-sheet readers.
# env.ts parses this and hides the raw string from JSON.stringify(env).
GOOGLE_SERVICE_ACCOUNT_KEY_JSON=
FINANCE_SHEET_ID=                    # Ongoing finance sheet ID (Phase 9+)

# --- Admin -------------------------------------------------------------------
ADMIN_EMAILS=                        # Comma-separated, case-insensitive (gmail-canonicalized)

# --- Mail (v1: SMTP via info@folgederwolke.de; flip to resend when DNS verifies) ---
MAIL_PROVIDER=smtp                   # smtp | resend
MAIL_FROM=info@folgederwolke.de
SMTP_HOST=                           # e.g. mail.your-hoster.de
SMTP_PORT=587
SMTP_USER=info@folgederwolke.de
SMTP_PASSWORD=

# --- Feature flags -----------------------------------------------------------
PUBLIC_FORM_ENABLED=true             # D4: ship public form to Externe immediately

# --- Production base URL -----------------------------------------------------
# REQUIRED in production. Magic-link emails reference this for the verify URL.
# Falls back to the request Host header when unset, which is spoofable —
# `assertProductionEnvSafe()` refuses to boot if this is missing in prod.
PUBLIC_BASE_URL=                     # e.g. https://folgederwolke-app.vercel.app

# --- Mail dev-eml sink -------------------------------------------------------
MAIL_EML_ROOT=./.dev-data/mail       # dev-eml provider sink (no real SMTP)

# --- Vercel cron auth --------------------------------------------------------
# REQUIRED for /api/cron/* endpoints. Vercel posts
# `Authorization: Bearer <CRON_SECRET>` on every scheduled cron invocation;
# the route handlers reject anything else. Generate with: openssl rand -base64 32
# Rotate via: gh secret set CRON_SECRET --body '<new>' AND update the Vercel
# Production env scope (both must match).
CRON_SECRET=                         # shared secret for Vercel → /api/cron/*

# --- Org constants -----------------------------------------------------------
VEREIN_NAME=Folge der Wolke e.V.
VEREIN_STEUERNUMMER=143/215/10028
VEREIN_VR=VR 211227
VEREIN_ADRESSE=Westermühlstraße 6, 80469 München

# Verein bank data — IBAN + BIC + Bankname (display).
# IBAN encodes the BLZ (positions 5-12); BIC must agree with the same bank.
# env.ts has a startup-time consistency check (assertVereinBankConsistent)
# that refuses to boot in prod if VEREIN_IBAN and VEREIN_BIC point at
# different banks. Required by beitragsreminder cron + manual reminder.
VEREIN_IBAN=                         # e.g. DE43 8306 5408 9999 9999 99 (shape only; real value in Vercel env)
VEREIN_BIC=                          # e.g. GENODEF1XXX
VEREIN_BANK=                         # e.g. Deutsche Skatbank

# Bescheid for Zuwendungsbestätigungen (supports §60a + Freistellungsbescheid)
VEREIN_BESCHEID_TYP=                 # feststellung_60a | freistellungsbescheid | (blank → disabled)
VEREIN_BESCHEID_DATUM=               # YYYY-MM-DD
VEREIN_SATZUNG_FASSUNG=              # YYYY-MM-DD — required for §60a wording
VEREIN_FREISTELLUNGSBESCHEID_VZ=     # YYYY — only used if TYP=freistellungsbescheid
VEREIN_STEUERBEGUENSTIGTE_ZWECKE=    # Free text — "Förderung der Kunst und Kultur ..." (BMF Pflichtfeld)

# --- Drive / Sheet references (importer) ------------------------------------
LIVE_SHEET_ID=
LIVE_FORM_ID=
EXISTING_RECHNUNGEN_FOLDER_ID=
EXISTING_BELEGE_FOLDER_ID=

# --- Backup ------------------------------------------------------------------
BACKUP_AGE_RECIPIENT=                # age public key; private key stored in 1Password

# --- Deployment metadata (set by CI, not manually) --------------------------
COMMIT_SHA=                          # injected by Vercel / GitHub Actions
DEPLOYED_AT=                         # ISO 8601 timestamp, injected at deploy time
